{
  "name": "aosora-shiori",
  "displayName": "Aosora SHIORI zh-cn",
  "publisher": "kanadelab",
  "description": "Aosora SHIORI extension zh-cn",
  "version": "1.0.9",
  "repository": "https://github.com/kanadelab/aosora-shiori.git",
  "icon": "aosora-icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aosora",
        "aliases": [
          "Aosora SHIORI",
          "aosora"
        ],
        "extensions": [
          ".as"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aosora",
        "scopeName": "aosora",
        "path": "./syntaxes/aosora.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "extension.aosora-shiori.debugEditorContents",
        "title": "Debug Ghost",
        "category": "Debug",
        "enablement": "!inDebugMode",
        "icon": "$(debug-alt)"
      },
      {
        "command": "aosora.sendcaret",
        "title": "发送到人格"
      }
    ],
    "breakpoints": [
      {
        "language": "aosora"
      }
    ],
    "keybindings":[
      {
        "command": "aosora.sendcaret",
        "key": "Alt+Q",
        "when": "resourceLangId == aosora"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "extension.aosora-shiori.debugEditorContents",
          "when": "resourceLangId == aosora",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "aosora.sendcaret",
          "when": "resourceLangId == aosora"
        }
      ]
    },
    "debuggers": [
      {
        "type": "aosora",
        "languages": [
          "aosora-shiori"
        ],
        "label": "Aosora Debugger",
        "initialConfigurations": [
          {
            "type": "aosora",
            "request": "launch",
            "name": "苍空调试",
            "port": 27016
          }
        ],
        "configurationSnippets": [
          {
            "label": "苍空调试",
            "description": "用于启动Aosora SHIORI的设置",
            "body": {
              "type": "aosora",
              "request": "launch",
              "name": "苍空调试",
              "port": 27016
            }
          },
          {
            "label": "苍空连接",
            "description": "连接到Aosora SHIORI的设置",
            "body": {
              "type": "aosora",
              "request": "attach",
              "name": "蒼空连接",
              "port": 27016
            }
          }
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "port": {
                "type": "number",
                "description": "要连接的端口号",
                "default": 27016
              }
            },
            "required": ["port"]
          },
          "attach": {
            "properties": {
              "port": {
                "type": "number",
                "description": "要连接的端口号",
                "default": 27016
              }
            },
            "required": ["port"]
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "iconv-lite": "^0.6.3",
    "zod": "^3.24.3"
  }
}